{
  "name": "msg-pool-services",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:cf": "wrangler pages dev . --d1=DB",
    "deploy:cf": "wrangler pages deploy .",
    "db:migrate:local": "wrangler d1 execute msg-pool-db --local --file=schema.sql",
    "db:migrate:remote": "wrangler d1 execute msg-pool-db --remote --file=schema.sql"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "hono": "^4.6.12",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "wrangler": "^3.94.0"
  }
}
